{
  "extends": ["config:best-practices", ":separateMultipleMajorReleases"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions digest updates",
      "groupName": "github-actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest", "pin", "minor", "patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor and patch updates",
      "groupName": "all-minor-patch",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true,
      "matchPackageNames": ["*"]
    },
    {
      "description": "Major updates need manual review",
      "groupName": "major",
      "matchUpdateTypes": ["major"],
      "assignees": ["elsbrock"],
      "matchPackageNames": ["*"]
    }
  ],
  "prCreation": "not-pending",
  "rebaseWhen": "behind-base-branch"
}
